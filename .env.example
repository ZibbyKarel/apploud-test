# GitLab personal access token (read-only is sufficient).
# Server-only: NOT prefixed with NEXT_PUBLIC_, so it never reaches the browser.
# Swap the token by editing this value in .env.local.
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Optional: override the GitLab base URL for self-hosted instances.
# GITLAB_BASE_URL=https://gitlab.com

# Optional: tune the shared rate limiter (src/api/utils/limiter.ts).
# GITLAB_MAX_RPM=1500          # max GitLab requests/min on the shared token (under ~2000 limit)
# GITLAB_MAX_CONCURRENT=8      # max requests in flight at once

# Optional: multi-instance deployments only. Behind a load balancer with N
# instances, set REDIS_URL to share ONE rate budget and ONE report cache across
# all of them (otherwise each instance limits/caches independently — N× the
# token's real rate). Leave unset for single-instance (`next start`).
# To try it end-to-end: `docker compose -f docker-compose.cluster.yml up --build`
# (redis + 2 app instances + nginx) — the cluster compose file injects REDIS_URL
# for you. The default `docker compose up` is single-instance. See docs/SCALABILITY.md.
# REDIS_URL=redis://localhost:6379
